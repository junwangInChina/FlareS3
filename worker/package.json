{
  "name": "flares3-worker",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --port 18787",
    "deploy": "wrangler deploy",
    "deploy:full": "wrangler deploy --config wrangler.full.toml",
    "test:build": "rm -rf .test-dist && tsc -p tsconfig.test.json --outDir .test-dist && node -e \"require('fs').writeFileSync('.test-dist/package.json', '{\\\"type\\\":\\\"commonjs\\\"}\\n')\"",
    "test": "npm run test:build && WORKER_TEST_OUTDIR=$PWD/.test-dist node --test tests/*.test.cjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1029.0",
    "@aws-sdk/s3-request-presigner": "^3.1029.0",
    "bcryptjs": "^2.4.3",
    "itty-router": "^4.0.0"
  },
  "overrides": {
    "fast-xml-parser": "5.5.11"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240909.0",
    "@types/bcryptjs": "^2.4.6",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.2.5",
    "typescript": "^5.5.4",
    "wrangler": "^3.88.0"
  }
}
